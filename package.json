{
  "name": "weather-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @weather-edge/web dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage.enabled --coverage.include=packages/core/src/** --coverage.exclude=packages/core/src/index.ts --coverage.exclude=packages/core/src/types.ts --coverage.thresholds.lines=95 --coverage.thresholds.functions=95 --coverage.reporter=text-summary",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "postgres": "^3.4.9",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "tz-lookup": "^6.1.25",
    "vitest": "^2.1.8"
  }
}
