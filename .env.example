# Weather Edge — environment variables (ARCHITECTURE.md §11.2).
# Copy to .env.local and fill in. Env is for SECRETS AND WIRING ONLY —
# all tunables (bankroll, caps, thresholds, α, σ priors, champion source,
# trading mode) live in the `config` TABLE and are edited via /admin.

# --- Supabase (operator: create project, then link — see BUILD-STATE.md Operator TODO) ---
SUPABASE_URL=                       # project URL (all runtimes)
SUPABASE_ANON_KEY=                  # RLS-scoped client (web)
SUPABASE_SERVICE_ROLE_KEY=          # service client (functions, scripts) — NEVER web
DATABASE_URL=                       # direct Postgres (scripts, migrations)

# --- Job auth ---
CRON_SECRET=                        # job endpoint auth, ≥32 chars; also seeded into Supabase Vault as 'cron_secret' (RUNBOOK)

# --- Alerts ---
SLACK_WEBHOOK_URL=                  # incoming-webhook URL for the notifier (functions)

# --- Open-Meteo (optional) ---
OPENMETEO_API_KEY=                  # paid tier; presence switches calls to customer- hosts (functions, scripts)

# --- Web ---
NEXT_PUBLIC_APP_URL=http://localhost:3000   # deep links in Slack messages (web, functions)
OPERATOR_EMAIL=                     # the single allowed login (web; RLS reads config key 'operatorEmail')
NEXT_PUBLIC_SUPABASE_URL=           # browser twin of SUPABASE_URL (login page; NEXT_PUBLIC_* is build-inlined)
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # browser twin of SUPABASE_ANON_KEY (anon key is public by design; RLS guards)

# --- Live trading ONLY (dormant until P10; ADR-10) ---
# POLY_PRIVATE_KEY=                 # wallet key — Supabase Edge Function secrets ONLY, never Vercel env
# POLY_FUNDER_ADDRESS=              # proxy-wallet params (live phase)
# POLY_SIGNATURE_TYPE=
